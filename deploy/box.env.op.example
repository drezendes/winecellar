# Committed template of the box's production env. Copy to deploy/box.env.op and
# replace the placeholders: `box` -> your 1Password vault name, example.com ->
# your domain. box.env.op is gitignored (it names your infra); op:// refs +
# non-secret literals only, never secrets.
#
# Generate straight onto the box (no plaintext ever hits your disk):
#   op inject -i deploy/box.env.op | ssh deploy@<box-ip> \
#     "cat > /opt/box/.env && chmod 600 /opt/box/.env"

DEBUG=False

# Site addresses: Caddy vhosts ({$WINE_HOST}/{$BLOG_HOST}/{$APEX_HOST}) + Django.
WINE_HOST=wine.example.com
BLOG_HOST=blog.example.com
APEX_HOST=example.com
ALLOWED_HOSTS=wine.example.com
CSRF_TRUSTED_ORIGINS=https://wine.example.com

SECRET_KEY=op://box/winecellar/SECRET_KEY
POSTGRES_PASSWORD=op://box/winecellar/POSTGRES_PASSWORD
ANTHROPIC_API_KEY=op://box/winecellar/ANTHROPIC_API_KEY

# Caddy DNS-01:
CLOUDFLARE_API_TOKEN=op://box/shared-box/CLOUDFLARE_API_TOKEN

# Nightly restic -> B2 backup:
RESTIC_PASSWORD=op://box/shared-box/RESTIC_PASSWORD
BACKBLAZE_BUCKET_NAME=op://box/shared-box/BACKBLAZE_BUCKET_NAME
BACKBLAZE_KEY_ID=op://box/shared-box/BACKBLAZE_KEY_ID
BACKBLAZE_APPLICATION_KEY=op://box/shared-box/BACKBLAZE_APPLICATION_KEY

# Blog tenant (subscriber export folded into the box backup):
BUTTONDOWN_API_KEY=op://box/shared-box/BUTTONDOWN_API_KEY
