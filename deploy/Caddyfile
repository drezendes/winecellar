# Example single-tenant edge for winecellar. Caddy owns :80/:443 + all TLS.
# TLS via Cloudflare DNS-01 so certs issue whether the host is gray- or
# orange-clouded (the CF proxy breaks TLS-ALPN). Reload after edits:
#   docker compose -f docker-compose.prod.yml exec caddy caddy reload --config /etc/caddy/Caddyfile
#
# The hostname comes from {$WINE_HOST} in .env (passed to the caddy service in
# docker-compose.prod.yml), so this file carries no site-specific domain.

{
	# DNS-01 using a Cloudflare Zone->DNS->Edit token from the env.
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	servers {
		# Trust Cloudflare's proxy IPs so logs/X-Forwarded-For show real
		# clients (ranges auto-refreshed by the caddy-cloudflare-ip module).
		trusted_proxies cloudflare {
			interval 12h
		}
	}
}

{$WINE_HOST} {
	encode zstd gzip
	# User-uploaded media (label scans) served from disk, not through Django
	# (Django only serves /media/ when DEBUG). Dir mounted in the compose file.
	handle_path /media/* {
		root * /srv/media
		file_server
	}
	handle {
		reverse_proxy web:8000
	}
}
