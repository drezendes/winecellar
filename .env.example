# Reference of every env var. the owner's setup keeps the real values in
# 1Password (vault box) and resolves them via the committed
# op:// templates — no plaintext needed:
#   op run --env-file=.env.op -- <cmd>        # workstation scripts + dev
#   op inject -i deploy/box.env.op > .env     # materialize a file if you want one
# This file stays as documentation / a non-1Password fallback. .env is
# gitignored. Dev needs only the Django + Claude blocks; the Production block
# is the box's /opt/box/.env (chmod 600). See deploy/README.md.

# --- Django ---
DEBUG=True
SECRET_KEY=generate-a-real-one-for-any-deployment
# ALLOWED_HOSTS=localhost,127.0.0.1
# TIME_ZONE=America/New_York
# CONSOLE_LOG_LEVEL=WARNING

# --- Claude API (https://platform.claude.com) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Distributor email polling (IMAP) ---
DISTRIBUTOR_IMAP_HOST=
DISTRIBUTOR_IMAP_USER=
DISTRIBUTOR_IMAP_PASSWORD=
# DISTRIBUTOR_IMAP_FOLDER=INBOX

# ======================================================================
# Production only — the box's /opt/box/.env. NEVER commit real values.
# ======================================================================
# Django prod: DEBUG=False, a real 50-char key, and the public origin.
#   SECRET_KEY: python -c "import secrets;print(secrets.token_urlsafe(64))"
# ALLOWED_HOSTS=wine.example.com
# CSRF_TRUSTED_ORIGINS=https://wine.example.com

# Postgres (compose builds DATABASE_URL from this):
#   POSTGRES_PASSWORD: python -c "import secrets;print(secrets.token_urlsafe(32))"
# POSTGRES_PASSWORD=

# Infra provisioning (shared with the blog repo):
# HCLOUD_TOKEN=            # Hetzner Cloud API (read/write) — provision.py
# CLOUDFLARE_API_TOKEN=    # Zone->DNS->Edit — Caddy DNS-01 AND dns.py
# CLOUDFLARE_ACCOUNT_ID=

# Backups -> Backblaze B2 (restic, client-side encrypted):
#   RESTIC_PASSWORD: generate + STORE IN 1PASSWORD — lose it, lose the backups.
# RESTIC_PASSWORD=
# BACKBLAZE_BUCKET_NAME=
# BACKBLAZE_KEY_ID=
# BACKBLAZE_APPLICATION_KEY=

# Blog tenant (its nightly subscriber export folds into the box backup):
# BUTTONDOWN_API_KEY=
