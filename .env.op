# Workstation env, resolved from 1Password (vault: box).
# Contains only 1Password secret references + non-secret literals — safe to commit.
#
#   op run --env-file=.env.op -- <cmd>   # inject into a process, no file on disk
#   op inject -i .env.op -o .env         # materialize a throwaway .env (regenerable)
#
# Dev needs only DEBUG + ANTHROPIC_API_KEY; the rest are for scripts/deploy/*.

DEBUG=True
ANTHROPIC_API_KEY=op://box/winecellar/ANTHROPIC_API_KEY

# Infra (provision.py / dns.py):
HCLOUD_TOKEN=op://box/shared-box/HCLOUD_TOKEN
CLOUDFLARE_API_TOKEN=op://box/shared-box/CLOUDFLARE_API_TOKEN
CLOUDFLARE_ACCOUNT_ID=op://box/shared-box/CLOUDFLARE_ACCOUNT_ID
